{
  "title": "zbar Docs Explorer",
  "icon": "/__repo_root/assets/icon/zbar-icon.png",
  "brandWordmarkText": "bar",
  "repoBasePath": "/__repo_root/",
  "repoUrl": "https://github.com/LaurenceGuws/zbar",
  "runtimeMode": "local-dev",
  "defaultDoc": "README.md",
  "docsIndexPath": "./docs-index.zbar.json",
  "theme": {
    "dark": {
      "accent": "#47b8ff",
      "accentSoft": "rgba(71, 184, 255, 0.14)",
      "accentStrong": "#7fd2ff",
      "activeLink": "#d4f0ff",
      "panel": "#0f1822",
      "panel2": "#14202c",
      "panel3": "#1a2937",
      "bg": "#09111a",
      "bg2": "#101a25"
    },
    "light": {
      "accent": "#1f7fc9",
      "accentSoft": "rgba(31, 127, 201, 0.12)",
      "accentStrong": "#15629d",
      "activeLink": "#103d61",
      "panel": "#eef6fb",
      "panel2": "#f7fbfe",
      "panel3": "#dfeef8",
      "bg": "#e7f1f8",
      "bg2": "#d4e7f3"
    }
  },
  "docRoots": [
    ".",
    "docs",
    "app_architecture"
  ],
  "includeExtensions": [
    ".md",
    ".yaml"
  ]
}
